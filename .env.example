# Direct connection to the database. Used for SQLAlchemy + migrations.
SUPABASE_DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# OpenRouter API key
OPENROUTER_API_KEY="sk-or-v1-your-openrouter-key"

# LangSmith tracing
LANGCHAIN_API_KEY="your-langchain-api-key"
LANGCHAIN_PROJECT="synaptiqpay-recommendations"

# Rate limit per IP per day for the analyze endpoint
MAX_PER_IP_DAILY=10

# Allowed CORS origin for the frontend (set to Vercel URL in production)
FRONTEND_ORIGIN="http://localhost:5173"

# "development" enables /docs and /redoc; anything else disables them
ENVIRONMENT="development"
