# Direct connection to the database. Used for SQLAlchemy + migrations.
SUPABASE_DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# OpenRouter API key
OPENROUTER_API_KEY="sk-or-v1-your-openrouter-key"

# LangSmith tracing
LANGCHAIN_API_KEY="your-langchain-api-key"
LANGCHAIN_PROJECT="your-langchain-project"

# Rate limit per IP per day for the analyze endpoint
MAX_PER_IP_DAILY=10

# Secret salt used to hash client IPs before storage (raw IPs are never
# persisted). Set a stable random value in production; changing it resets
# per-IP rate-limit counts.
IP_HASH_SALT=""

# Allowed CORS origin for the frontend (set to Railway frontend URL in production)
FRONTEND_ORIGIN="http://localhost:5173"

# "development" enables /docs and /redoc; anything else (incl. unset) disables
# them. Keep this as "production" anywhere it is publicly reachable.
ENVIRONMENT="production"
